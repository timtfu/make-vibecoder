{
    "name": "Create a new call log in Salesflare from a new call in RingCentral",
    "flow": [
        {
            "id": 1,
            "module": "ringcentral:watchCalls",
            "version": 1,
            "parameters": {
                "limit": 1000
            },
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 150
                },
                "restore": {},
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    },
                    {
                        "name": "limit",
                        "type": "uinteger",
                        "label": "Limit",
                        "required": true
                    },
                    {
                        "name": "type",
                        "type": "select",
                        "label": "Type",
                        "validate": {
                            "enum": [
                                "user",
                                "company"
                            ]
                        }
                    },
                    {
                        "name": "companyId",
                        "type": "select",
                        "label": "Account/Company ID",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 2,
            "module": "salesflare:findContact",
            "version": 1,
            "parameters": {},
            "mapper": {
                "limit": "1",
                "phone_number": "{{1.from.phoneNumber}}"
            },
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 150
                },
                "restore": {
                    "id": {
                        "mode": "chose"
                    },
                    "name": {
                        "mode": "edit"
                    },
                    "email": {
                        "mode": "edit"
                    },
                    "account": {
                        "mode": "chose",
                        "label": ""
                    },
                    "tag__name": {
                        "mode": "edit"
                    },
                    "phone_number": {
                        "mode": "edit"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "id",
                        "type": "select",
                        "label": "Contact ID",
                        "multiple": true
                    },
                    {
                        "mode": "edit",
                        "name": "name",
                        "type": "select",
                        "label": "Name"
                    },
                    {
                        "mode": "edit",
                        "name": "email",
                        "type": "select",
                        "label": "Email"
                    },
                    {
                        "mode": "edit",
                        "name": "phone_number",
                        "type": "select",
                        "label": "Phone Number"
                    },
                    {
                        "name": "account",
                        "type": "select",
                        "label": "Account ID"
                    },
                    {
                        "mode": "edit",
                        "name": "tag__name",
                        "type": "select",
                        "label": "Tag",
                        "multiple": true
                    },
                    {
                        "name": "limit",
                        "type": "uinteger",
                        "label": "Limit"
                    },
                    {
                        "name": "custom",
                        "spec": [],
                        "type": "collection",
                        "label": "Custom Fields"
                    }
                ]
            }
        },
        {
            "id": 12,
            "module": "util:SetVariable2",
            "version": 1,
            "parameters": {},
            "mapper": {
                "name": "json_for_salesflare",
                "scope": "roundtrip",
                "value": "\t{\n\t\"custom\": {\n\t\t\"ringcentral_calls\": \"{{replace(get(2.custom; \"ringcentral_calls\"); newline; \"\\n\")}}\\nCall at {{formatDate(1.startTime; \"YYYY-MM-DD HH:mm:ss\")}} | Action: {{1.action}} | Result: {{1.result}}\"\n\t\t}\n\t}"
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 150
                },
                "restore": {
                    "scope": {
                        "label": "One cycle"
                    }
                },
                "expect": [
                    {
                        "name": "name",
                        "type": "text",
                        "label": "Variable name",
                        "required": true
                    },
                    {
                        "name": "scope",
                        "type": "select",
                        "label": "Variable lifetime",
                        "required": true,
                        "validate": {
                            "enum": [
                                "roundtrip",
                                "execution"
                            ]
                        }
                    },
                    {
                        "name": "value",
                        "type": "any",
                        "label": "Variable value"
                    }
                ],
                "interface": [
                    {
                        "name": "json_for_salesflare",
                        "type": "any",
                        "label": "json_for_salesflare"
                    }
                ]
            }
        },
