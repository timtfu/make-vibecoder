        {
            "id": 8,
            "module": "code:ExecuteCode",
            "version": 0,
            "parameters": {},
            "mapper": {
                "input": [
                    {
                        "name": "allTags",
                        "value": "{{ifempty(10.array; \"[]\")}}"
                    },
                    {
                        "name": "tagNamesToAdd",
                        "value": "{{ifempty(var.input.tagNamesToAdd; \"[]\")}}"
                    },
                    {
                        "name": "tagNamesToRemove",
                        "value": "{{ifempty(var.input.tagNamesToRemove; \"[]\")}}"
                    }
                ],
                "language": "javascript",
                "inputFormat": "editor",
                "dependencies": [],
                "codeEditorJavascript": "// Retrieve input variables\nconst allTags = Array.isArray(input?.allTags) ? input.allTags : [];\nconst tagNamesToAdd = Array.isArray(input?.tagNamesToAdd) ? input.tagNamesToAdd : [];\nconst tagNamesToRemove = Array.isArray(input?.tagNamesToRemove) ? input.tagNamesToRemove : [];\n\n// Helpers\nconst normalizeString = (s) => String(s ?? '').trim();\nconst normalizeKey = (s) => normalizeString(s).toLowerCase();\n\n// Build lookup: tag name -> tag ID\n// allTags items expected like: { label: \"Tag name\", value: \"123\" }\nconst tagNameToId = {};\nfor (const tag of allTags) {\n  if (!tag || typeof tag.label !== 'string') {\n    continue;\n  }\n  const id = Number(tag.value);\n  if (Number.isNaN(id)) {\n     continue;\n  }\n  tagNameToId[normalizeKey(tag.label)] = id;\n}\n\n// Resolve names -> IDs (dedupe, ignore unknown)\nconst getUniqueNormalizedKeys = (arr) => [...new Set(arr.map(normalizeKey).filter(k => k !== ''))];\n\nconst addKeys = getUniqueNormalizedKeys(tagNamesToAdd);\nconst removeKeys = getUniqueNormalizedKeys(tagNamesToRemove);\n\nconst tagIdsToAdd = addKeys\n  .map(k => tagNameToId[k])\n  .filter(id => typeof id === 'number' && !Number.isNaN(id));\n\nconst tagIdsToRemove = removeKeys\n  .map(k => tagNameToId[k])\n  .filter(id => typeof id === 'number' && !Number.isNaN(id));\n\nreturn {\n  tagIdsToAdd,\n  tagIdsToRemove\n};"
            },
            "metadata": {
                "designer": {
                    "x": 900,
                    "y": 300,
                    "name": "Determine tag changes (add/remove)"
                },
