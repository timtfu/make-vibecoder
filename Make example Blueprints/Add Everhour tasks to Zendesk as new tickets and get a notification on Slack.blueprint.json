                "designer": {
                    "x": 600,
                    "y": 0
                },
                "restore": {
                    "client": {
                        "mode": "edit"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
