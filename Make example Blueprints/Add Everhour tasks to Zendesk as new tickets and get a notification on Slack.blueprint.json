{
    "name": "Add Everhour tasks to Zendesk as new tickets and get a notification on Slack",
    "flow": [
        {
            "id": 1,
            "module": "everhour:TriggerWatchNewTasks",
            "version": 1,
            "parameters": {},
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 0
                },
                "restore": {},
                "parameters": [
                    {
                        "name": "__IMTHOOK__",
                        "type": "hook",
                        "label": "Webhook",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 2,
            "module": "everhour:ActionGetAProject",
            "version": 1,
            "parameters": {},
            "mapper": {
                "projectID": "{{1.projects[]}}"
            },
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 0
                },
                "restore": {
                    "projectID": {
                        "mode": "edit"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "mode": "edit",
                        "name": "projectID",
                        "type": "select",
                        "label": "Project ID",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 3,
            "module": "everhour:ActionGetAClient",
            "version": 1,
            "parameters": {},
            "mapper": {
                "client": "{{2.client}}"
