{
    "name": "Pause or activate all campaigns in a Google Ads account from an incoming webhook",
    "flow": [
        {
            "id": 1,
            "module": "gateway:CustomWebHook",
            "version": 1,
            "parameters": {
                "maxResults": 1
            },
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 0
                },
                "restore": {},
                "parameters": [
                    {
                        "name": "hook",
                        "type": "hook",
                        "label": "Webhook",
                        "required": true
                    },
                    {
                        "name": "maxResults",
                        "type": "number",
                        "label": "Maximum number of results"
                    }
                ],
                "interface": [
                    {
                        "name": "action",
                        "type": "text"
                    },
                    {
                        "name": "customerId",
                        "type": "text"
                    }
                ]
            }
        },
        {
            "id": 3,
            "module": "util:SetVariables",
            "version": 1,
            "parameters": {},
            "filter": {
                "name": "action check",
                "conditions": [
                    [
                        {
                            "a": "{{lower(trim(1.action))}}",
                            "b": "pause",
                            "o": "text:equal"
                        }
                    ],
                    [
                        {
                            "a": "{{lower(trim(1.action))}}",
                            "b": "activate",
                            "o": "text:equal"
                        }
                    ]
                ]
            },
            "mapper": {
                "scope": "roundtrip",
                "variables": [
                    {
                        "name": "status_for_filter",
                        "value": "{{switch(lower(1.action); \"pause\"; \"ENABLED\"; \"activate\"; \"PAUSED\")}}"
                    },
                    {
                        "name": "target_status",
                        "value": "{{switch(lower(1.action); \"pause\"; \"PAUSED\"; \"activate\"; \"ENABLED\")}}"
                    },
                    {
                        "name": "normalized_customer_id",
                        "value": "{{trim(replace(1.customerId; \"-\"; emptystring))}}"
                    }
                ]
            },
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 0
                },
                "restore": {
                    "scope": {
                        "label": "One cycle"
                    },
                    "variables": {
                        "items": [
                            "undefined",
                            "undefined",
                            "undefined"
                        ]
                    }
                },
                "expect": [
                    {
                        "name": "variables",
                        "spec": [
                            {
                                "name": "name",
                                "type": "text",
                                "label": "Variable name",
                                "required": true
                            },
                            {
                                "name": "value",
                                "type": "any",
                                "label": "Variable value"
                            }
                        ],
                        "type": "array",
                        "label": "Variables"
                    },
                    {
                        "name": "scope",
                        "type": "select",
                        "label": "Variable lifetime",
                        "required": true,
                        "validate": {
                            "enum": [
                                "roundtrip",
                                "execution"
                            ]
                        }
                    }
                ],
                "interface": [
                    {
                        "name": "status_for_filter",
                        "type": "any",
                        "label": "status_for_filter"
                    },
                    {
                        "name": "target_status",
                        "type": "any",
                        "label": "target_status"
                    },
                    {
                        "name": "normalized_customer_id",
                        "type": "any",
                        "label": "normalized_customer_id"
                    }
                ]
            }
        },
        {
            "id": 7,
            "module": "google-ads-campaign-management:getAnAccount",
            "version": 1,
            "parameters": {},
            "filter": {
                "name": "customer ID is a number",
                "conditions": [
                    [
                        {
                            "a": "{{average(1.customerId)}}",
                            "b": "0",
                            "o": "number:greater"
                        }
                    ]
                ]
            },
            "mapper": {
                "account": "{{3.normalized_customer_id}}"
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 0
                },
                "restore": {
                    "account": {
                        "mode": "edit"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "mode": "edit",
                        "name": "account",
                        "type": "select",
                        "label": "Account/Customer ID",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 2,
            "module": "google-ads-campaign-management:listCampaigns",
            "version": 1,
            "parameters": {},
            "filter": {
                "name": "account found",
                "conditions": [
                    [
                        {
                            "a": "{{7.id}}",
                            "b": "",
                            "o": "exist"
                        }
                    ]
                ]
            },
            "mapper": {
                "limit": "1000",
                "filter": [
                    [
                        {
                            "a": "campaign.status || ENUM",
                            "b": "{{3.status_for_filter}}",
                            "o": "="
                        }
                    ]
                ],
                "select": "filter",
                "clientId": "{{1.customerId}}"
            },
            "metadata": {
                "designer": {
                    "x": 900,
                    "y": 0
                },
                "restore": {
                    "select": {
                        "label": "Search Campaigns by Filter"
                    },
                    "clientId": {
                        "mode": "edit"
                    }
                },
                "parameters": [
