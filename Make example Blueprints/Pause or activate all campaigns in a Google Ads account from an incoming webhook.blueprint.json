                            "a": " {{5.`__IMTAGGLENGTH__`}}",
                            "b": "0",
                            "o": "number:greater"
                        }
                    ]
                ]
            },
            "mapper": {
                "cc": [],
                "bcc": [],
                "from": "",
                "html": "The list of changed campaigns:<br>\n{{join(map(5.array; \"name\"); \"<br>\")}}",
                "sender": "",
                "headers": [],
                "replyTo": "",
                "subject": "Campaigns {{3.target_status}} in {{7.descriptiveName}} | {{3.normalized_customer_id}}",
                "priority": "normal",
                "inReplyTo": "",
                "references": [],
                "attachments": [],
                "contentType": "html"
            },
