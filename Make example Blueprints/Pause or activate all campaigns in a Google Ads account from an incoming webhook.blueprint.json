        {
            "id": 4,
            "module": "google-ads-campaign-management:updateACampaign",
            "version": 1,
            "parameters": {},
            "filter": {
                "name": "campaigns found",
                "conditions": [
                    [
                        {
                            "a": "{{2.id}}",
                            "b": "",
                            "o": "exist"
                        }
                    ]
                ]
            },
            "mapper": {
                "select": "status",
                "status": "{{3.target_status}}",
                "campaign": "{{2.id}}",
                "clientId": "{{1.customerId}}"
            },
            "metadata": {
                "designer": {
                    "x": 1200,
                    "y": 0
                },
                "restore": {
                    "select": {
                        "label": "Update a Campaign Status"
                    },
                    "status": {
                        "mode": "edit"
                    },
                    "clientId": {
                        "mode": "edit"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "select",
                        "type": "select",
                        "label": "Select a Method",
                        "required": true,
                        "validate": {
                            "enum": [
                                "status",
                                "budget",
                                "keyword",
                                "placement",
                                "add_label",
                                "remove_label"
                            ]
                        }
                    },
                    {
                        "mode": "edit",
                        "name": "clientId",
                        "type": "select",
                        "label": "Account/Customer ID",
                        "required": true
                    },
                    {
                        "name": "status",
                        "type": "select",
                        "label": "Status",
                        "required": true,
                        "validate": {
                            "enum": [
                                "ENABLED",
                                "PAUSED",
                                "REMOVED"
                            ]
                        }
                    },
                    {
                        "name": "campaign",
                        "type": "any",
                        "label": "Campaign ID",
                        "required": true
                    }
                ]
            }
        },
