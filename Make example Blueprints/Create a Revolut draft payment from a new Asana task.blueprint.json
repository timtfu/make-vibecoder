{
    "name": "Create a Revolut draft payment from a new Asana task",
    "flow": [
        {
            "id": 1,
            "module": "asana:WatchNewTasks",
            "version": 2,
            "parameters": {
                "page": 10,
                "filter": "project",
                "modified_since": null,
                "completed_since": null
            },
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 0
                },
                "restore": {
                    "filter": {
                        "label": "Project"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    },
                    {
                        "name": "filter",
                        "type": "select",
                        "label": "Filter",
                        "required": true,
                        "validate": {
                            "enum": [
                                "workspaceassignee",
                                "project",
                                "projectalternative",
                                "section",
                                "tag"
                            ]
                        }
                    },
                    {
                        "name": "completed_since",
                        "type": "date",
                        "label": "Completed Since"
                    },
                    {
                        "name": "modified_since",
                        "type": "date",
                        "label": "Modified Since "
                    },
                    {
                        "name": "page",
                        "type": "uinteger",
                        "label": "Limit",
                        "required": true
                    },
                    {
                        "name": "project",
                        "type": "select",
                        "label": "Project ID",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 2,
            "module": "airtable:ActionSearchRecords",
            "version": 3,
            "parameters": {},
