        {
            "id": 3,
            "module": "revolut:createDraftPayment",
            "version": 3,
            "parameters": {},
            "mapper": {
                "title": "Draft payment to {{1.name}}",
                "transfers": [
                    {
                        "bic": "{{2.BIC}}",
                        "city": "{{2.City}}",
                        "iban": "{{2.IBAN}}",
                        "name": "{{1.name}}",
                        "amount": "{{1.notes}}",
                        "postalCode": "{{2.`Postal code`}}",
                        "addressLine1": "{{2.`Street address`}}",
                        "recipientType": "INDIVIDUAL",
                        "paymentReference": "sample_payment",
                        "recipientCountry": "DE"
                    }
                ],
                "scheduledDate": "{{addDays(now; 1)}}"
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 0
                },
                "restore": {
                    "transfers": {
                        "mode": "chose",
                        "items": [
                            {
                                "recipientType": {
                                    "mode": "chose",
                                    "label": "Individual"
                                },
                                "recipientCountry": {
                                    "mode": "chose",
                                    "label": "Germany"
                                }
                            }
                        ]
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "recipientBankCountry",
                        "type": "select",
                        "label": "Recipient Bank Country",
                        "required": true
                    },
                    {
                        "name": "title",
                        "type": "text",
                        "label": "Draft Payment Title"
                    },
                    {
                        "name": "scheduledDate",
                        "time": false,
                        "type": "date",
                        "label": "Execution Date"
                    },
                    {
                        "name": "currency",
                        "type": "select",
                        "label": "Currency",
                        "required": true
                    },
                    {
                        "name": "transfers",
                        "spec": [
                            {
                                "name": "name",
                                "type": "text",
                                "label": "Name",
                                "required": true,
                                "validate": {
                                    "max": 80
                                }
                            },
                            {
                                "name": "recipientType",
                                "type": "select",
                                "label": "Recipient Type",
                                "options": [
                                    {
                                        "label": "Individual",
                                        "value": "INDIVIDUAL"
                                    },
                                    {
                                        "label": "Company",
                                        "value": "COMPANY"
                                    }
                                ],
                                "required": true
                            },
                            {
                                "name": "iban",
                                "type": "text",
                                "label": "IBAN",
                                "required": true
                            },
                            {
                                "name": "bic",
                                "type": "text",
                                "label": "BIC / SWIFT Code",
                                "required": true
                            },
                            {
                                "name": "amount",
                                "type": "number",
                                "label": "Amount",
                                "required": true
                            },
                            {
                                "name": "paymentReference",
                                "type": "text",
                                "label": "Payment Reference",
                                "required": true,
                                "validate": {
                                    "max": 100
                                }
                            },
                            {
                                "name": "recipientCountry",
                                "type": "select",
                                "label": "Recipient Country",
                                "required": true
                            },
                            {
                                "name": "addressLine1",
                                "type": "text",
                                "label": "Address Line 1",
                                "required": true,
                                "validate": {
                                    "max": 50
                                }
                            },
                            {
                                "name": "addressLine2",
                                "type": "text",
                                "label": "Address Line 2",
                                "validate": {
                                    "max": 50
                                }
                            },
                            {
                                "name": "city",
                                "type": "text",
                                "label": "City",
                                "required": true,
                                "validate": {
                                    "max": 50
                                }
                            },
                            {
                                "name": "postalCode",
                                "type": "text",
                                "label": "Postal Code",
                                "required": true,
                                "validate": {
                                    "max": 50
                                }
                            }
                        ],
                        "type": "array",
                        "label": "Transfers",
                        "required": true,
                        "validate": {
                            "maxItems": 50
                        }
                    }
                ]
            }
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {
