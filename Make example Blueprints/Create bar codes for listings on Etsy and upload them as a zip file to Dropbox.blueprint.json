{
    "name": "Create bar codes for listings on Etsy and upload them as a zip file to Dropbox",
    "flow": [
        {
            "id": 15,
            "module": "etsy:listListings",
            "version": 2,
            "parameters": {},
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 0
                },
                "restore": {},
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account:etsy3",
                        "label": "Connection"
                    }
                ]
            }
        },
        {
            "id": 2,
            "module": "barcode:GenerateBarcode",
            "version": 1,
            "parameters": {},
            "mapper": {
                "bcid": "qrcode",
                "text": "{{15.listing_id}}",
                "scale": "1",
                "rotate": "N",
                "eclevel": "M",
                "fileName": "{{15.title}}.png",
                "paddingwidth": "",
                "paddingheight": ""
            },
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 0
                },
                "restore": {
                    "expect": {
                        "bcid": {
                            "label": "QR Code"
                        },
                        "rotate": {
                            "label": "Normal (not rotated)"
                        },
                        "eclevel": {
                            "label": "Level M (15%)"
                        }
                    }
                },
                "expect": [
                    {
                        "name": "bcid",
                        "type": "select",
                        "label": "Barcode type",
                        "required": true,
                        "validate": {
                            "enum": [
                                "code39",
                                "code128",
                                "ean8",
                                "ean13",
                                "qrcode",
                                "upca",
                                "upce"
                            ]
                        }
                    },
                    {
                        "name": "text",
                        "type": "text",
                        "label": "Text",
                        "required": true
                    },
                    {
                        "name": "fileName",
                        "type": "filename",
                        "label": "File name",
                        "required": true,
                        "extension": "png"
                    },
                    {
                        "name": "paddingwidth",
                        "type": "uinteger",
                        "label": "Padding width"
                    },
                    {
                        "name": "paddingheight",
                        "type": "uinteger",
                        "label": "Padding height"
                    },
                    {
                        "name": "scale",
                        "type": "uinteger",
                        "label": "Scale",
                        "validate": {
                            "max": 10,
                            "min": 1
                        }
                    },
                    {
                        "name": "rotate",
                        "type": "select",
                        "label": "Rotate",
                        "validate": {
                            "enum": [
                                "N",
                                "R",
                                "L",
                                "I"
                            ]
                        }
                    },
                    {
                        "name": "eclevel",
                        "type": "select",
                        "label": "Error correction",
                        "validate": {
                            "enum": [
                                "L",
                                "M",
                                "Q",
                                "H"
                            ]
                        }
                    }
                ]
            }
        },
        {
            "id": 12,
            "module": "builtin:BasicAggregator",
            "version": 1,
            "parameters": {
                "feeder": 15
            },
            "mapper": {
                "data": "{{2.data}}",
                "filename": "{{2.fileName}}",
                "importType": "upload"
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 0
                },
                "restore": {
                    "extra": {
                        "feeder": {
                            "label": "Etsy - List Shop Listings"
                        },
                        "target": {
                            "label": "Import options: Input files"
                        }
                    },
                    "expect": {
                        "__IMTTARGET__": {
                            "nested": {
                                "importType": {
                                    "mode": "chose",
                                    "label": "upload a file"
                                }
                            }
                        }
                    }
                },
                "expect": [
                    {
                        "name": "importType",
                        "type": "select",
                        "label": "Input file",
                        "required": true,
                        "validate": {
                            "enum": [
                                "upload",
                                "url"
                            ]
                        }
                    },
                    {
                        "name": "data",
                        "type": "buffer",
                        "label": "Data",
                        "required": true
                    },
                    {
                        "name": "filename",
                        "type": "filename",
                        "label": "File name",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 13,
            "module": "cloudconvert:CreateArchive",
            "version": 2,
            "parameters": {},
            "mapper": {
                "export": {
                    "downloadFile": true
                },
                "import": {
                    "inputs": "{{12.array}}"
                },
                "options": {
                    "filename": "{{formatDate(now; \"DD.MM.YYYY\")}}.zip",
                    "output_format": "zip"
                }
            },
            "metadata": {
                "designer": {
                    "x": 900,
                    "y": 0
                },
                "restore": {
                    "export": {
                        "nested": {
                            "downloadFile": {
                                "mode": "chose"
                            }
                        }
                    },
                    "import": {
                        "nested": {
                            "inputs": {
                                "mode": "edit"
                            }
                        }
                    },
                    "options": {
                        "nested": {
                            "opts": {
                                "mode": "chose",
                                "items": []
                            },
                            "output_format": {
                                "mode": "chose",
                                "label": "zip"
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "import",
                        "spec": [
                            {
                                "name": "inputs",
                                "spec": [
                                    {
                                        "name": "importType",
                                        "type": "select",
                                        "label": "Input file",
                                        "options": [
                                            {
                                                "label": "upload a file",
                                                "value": "upload",
                                                "nested": [
                                                    {
                                                        "name": "data",
                                                        "type": "buffer",
                                                        "label": "Data",
                                                        "required": true,
                                                        "semantic": "file:data"
                                                    },
                                                    {
                                                        "name": "filename",
                                                        "type": "filename",
                                                        "label": "File name",
                                                        "required": true,
                                                        "semantic": "file:name"
                                                    }
                                                ]
                                            },
                                            {
                                                "label": "import a file from URL",
                                                "value": "url",
                                                "nested": [
                                                    {
                                                        "name": "url",
                                                        "type": "url",
                                                        "label": "URL",
                                                        "required": true
                                                    },
                                                    {
                                                        "name": "headers",
                                                        "spec": [
                                                            {
                                                                "name": "name",
                                                                "type": "text",
                                                                "label": "Name",
                                                                "required": true
                                                            },
                                                            {
                                                                "name": "value",
                                                                "type": "text",
                                                                "label": "Value",
                                                                "required": true
                                                            }
                                                        ],
                                                        "type": "array",
                                                        "label": "Headers",
                                                        "labels": {
                                                            "add": "Add a header",
                                                            "edit": "Update a header"
                                                        }
                                                    }
                                                ]
                                            }
                                        ],
                                        "required": true
                                    }
                                ],
                                "type": "array",
                                "label": "Input files",
                                "labels": {
                                    "add": "Add a file",
                                    "edit": "Update a file"
                                },
                                "required": true,
                                "validate": {
                                    "minItems": 1
                                }
                            }
                        ],
                        "type": "collection",
                        "label": "Import options",
                        "required": true
                    },
                    {
                        "name": "options",
                        "spec": [
                            {
                                "name": "output_format",
                                "type": "select",
                                "label": "Output format",
                                "required": true,
                                "validate": {
                                    "enum": [
                                        "7z",
                                        "rar",
                                        "tar",
                                        "tar.bz2",
                                        "tar.gz",
                                        "zip"
                                    ]
                                }
                            },
                            {
                                "name": "filename",
                                "type": "filename",
                                "label": "File name",
                                "required": true
                            },
                            {
                                "name": "opts",
                                "spec": [
                                    {
                                        "name": "name",
                                        "type": "text",
                                        "label": "Name",
                                        "required": true
                                    },
                                    {
                                        "name": "value",
                                        "type": "text",
                                        "label": "Value"
                                    }
                                ],
                                "type": "array",
                                "label": "Conversion and engine specific options",
                                "labels": {
                                    "add": "Add an option",
                                    "edit": "Update an option"
                                }
                            }
                        ],
                        "type": "collection",
                        "label": "Archive options",
                        "required": true
                    },
                    {
                        "name": "export",
                        "spec": [
                            {
                                "name": "downloadFile",
                                "type": "boolean",
                                "label": "Download a file",
                                "required": true
                            }
                        ],
                        "type": "collection",
                        "label": "Export options",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 14,
            "module": "dropbox:uploadLargeFile",
            "version": 5,
            "parameters": {},
            "mapper": {
                "data": "{{13.data}}",
                "filename": "{{13.filename}}",
                "overwrite": false
            },
            "metadata": {
                "designer": {
                    "x": 1200,
                    "y": 0
                },
                "restore": {
                    "overwrite": {
                        "mode": "chose"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "path",
                        "type": "folder",
                        "label": "Folder",
                        "required": true
                    },
                    {
                        "mean": "name",
                        "name": "filename",
                        "type": "filename",
                        "label": "File Name",
                        "required": true
                    },
                    {
                        "mean": "data",
                        "name": "data",
                        "type": "buffer",
                        "label": "Data",
                        "required": true
                    },
                    {
                        "name": "overwrite",
                        "type": "boolean",
                        "label": "Overwrite an existing file",
                        "required": true
                    }
                ]
            }
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {
            "orphans": []
        },
        "zone": "eu1.make.com",
        "notes": []
    }
}