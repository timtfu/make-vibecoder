{
    "name": "Sends information from posts in VK.com to SMS to the phone via Clickatell",
    "flow": [
        {
            "id": 10,
            "module": "vk-com:NewPost",
            "version": 1,
            "parameters": {
                "limit": 2,
                "domain": "",
                "filter": "all"
            },
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 150
                },
                "restore": {
                    "filter": {
                        "label": "all"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    },
                    {
                        "name": "filter",
                        "type": "select",
                        "label": "Filter",
                        "validate": {
                            "enum": [
                                "all",
                                "owner",
                                "others",
                                "timed posts",
                                "suggests"
                            ]
                        }
                    },
                    {
                        "name": "owner_id",
                        "type": "number",
                        "label": "Owner ID"
                    },
                    {
                        "name": "domain",
                        "type": "text",
                        "label": "Domain"
                    },
                    {
                        "name": "limit",
                        "type": "uinteger",
                        "label": "Limit",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 5,
            "module": "builtin:BasicRouter",
            "version": 1,
            "filter": {
                "name": "Text",
                "conditions": [
                    [
                        {
                            "a": "{{10.text}}",
                            "b": "",
                            "o": "exist"
                        }
                    ]
                ]
            },
            "mapper": null,
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 150
                }
            },
            "routes": [
                {
                    "flow": [
                        {
                            "id": 6,
                            "module": "clickatell:newSms",
                            "version": 1,
                            "parameters": {},
                            "filter": {
                                "name": "Not from owner",
                                "conditions": [
                                    [
                                        {
                                            "a": "{{10.owner_id}}",
                                            "b": "{{10.from_id}}",
                                            "o": "number:notequal"
                                        }
                                    ]
                                ]
                            },
                            "mapper": {
                                "content": "{{if(length(10.text) <= 30; 10.text; \"new post \" + 10.from_id)}}"
                            },
                            "metadata": {
                                "designer": {
                                    "x": 600,
                                    "y": 0
                                },
                                "restore": {},
                                "parameters": [
                                    {
                                        "name": "__IMTCONN__",
                                        "type": "account",
                                        "label": "Connection",
                                        "required": true
                                    }
                                ],
                                "expect": [
                                    {
                                        "name": "content",
                                        "type": "text",
                                        "label": "Content",
                                        "required": true
                                    },
                                    {
                                        "name": "to",
                                        "spec": {
                                            "type": "text",
                                            "label": "Number"
                                        },
                                        "type": "array",
                                        "label": "To",
                                        "required": true
                                    }
                                ]
                            }
                        }
                    ]
                },
                {
                    "flow": [
                        {
                            "id": 3,
                            "module": "clickatell:newSms",
                            "version": 1,
                            "parameters": {},
                            "filter": {
                                "name": "From owner",
                                "conditions": [
                                    [
                                        {
                                            "a": "{{10.owner_id}}",
                                            "b": "{{10.from_id}}",
                                            "o": "number:equal"
                                        }
                                    ]
                                ]
                            },
                            "mapper": {
                                "content": "{{if(length(10.text) <= 30; 10.text; \"new post \" + 10.from_id)}}"
                            },
                            "metadata": {
                                "designer": {
                                    "x": 600,
                                    "y": 300
                                },
                                "restore": {},
                                "parameters": [
                                    {
                                        "name": "__IMTCONN__",
                                        "type": "account",
                                        "label": "Connection",
                                        "required": true
                                    }
                                ],
                                "expect": [
                                    {
                                        "name": "content",
                                        "type": "text",
                                        "label": "Content",
                                        "required": true
                                    },
                                    {
                                        "name": "to",
                                        "spec": {
                                            "type": "text",
                                            "label": "Number"
                                        },
                                        "type": "array",
                                        "label": "To",
                                        "required": true
                                    }
                                ]
                            }
                        }
                    ]
                }
            ]
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {
            "orphans": []
        },
        "zone": "eu1.make.com",
        "notes": []
    }
}