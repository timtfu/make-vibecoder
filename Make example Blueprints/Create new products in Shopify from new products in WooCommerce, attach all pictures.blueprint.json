{
    "name": "Create new products in Shopify from new products in WooCommerce, attach all pictures",
    "flow": [
        {
            "id": 2,
            "module": "woocommerce:WatchProducts",
            "version": 2,
            "parameters": {
                "limit": 10
            },
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 0
                },
                "restore": {},
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    },
                    {
                        "name": "limit",
                        "type": "number",
                        "label": "Limit",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 10,
            "module": "builtin:BasicFeeder",
            "version": 1,
            "parameters": {},
            "mapper": {
                "array": "{{2.images}}"
            },
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 0
                },
                "restore": {
                    "array": {
                        "mode": "edit"
                    }
                },
                "expect": [
                    {
                        "mode": "edit",
                        "name": "array",
                        "spec": [],
                        "type": "array",
                        "label": "Array"
                    }
                ]
            }
        },
        {
            "id": 8,
            "module": "http:ActionGetFile",
            "version": 3,
            "parameters": {
                "handleErrors": false
            },
            "mapper": {
                "url": "{{10.src}}",
                "method": "get",
                "shareCookies": false
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 0
                },
                "parameters": [
                    {
                        "name": "handleErrors",
                        "type": "boolean",
                        "label": "Evaluate all states as errors (except for 2xx and 3xx )",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "url",
                        "type": "url",
                        "label": "URL",
                        "required": true
                    },
                    {
                        "name": "method",
                        "type": "hidden",
                        "label": "Method"
                    },
                    {
                        "name": "shareCookies",
                        "type": "boolean",
                        "label": "Share cookies with other HTTP modules",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 9,
            "module": "builtin:BasicAggregator",
            "version": 1,
            "parameters": {
                "feeder": 10,
                "target": "3.images"
            },
            "mapper": {
                "alt": "{{10.alt}}",
                "data": "{{8.data}}",
                "position": "{{10.position}}"
            },
            "metadata": {
                "designer": {
                    "x": 900,
                    "y": 0
                },
                "restore": {
                    "feeder": {
                        "label": "Iterator"
                    },
                    "target": {
                        "label": "Images"
                    }
                },
                "expect": [
                    {
                        "name": "data",
                        "type": "buffer",
                        "label": "Data",
                        "required": true
                    },
                    {
                        "name": "alt",
                        "type": "text",
                        "label": "Alternate text"
                    },
                    {
                        "name": "position",
                        "type": "number",
                        "label": "Position"
                    }
                ]
            }
        },
        {
            "id": 3,
            "module": "shopify:CreateProduct",
            "version": 2,
            "parameters": {},
            "mapper": {
                "title": "{{2.name}}",
                "images": "{{9.array}}",
                "variants": [
                    {
                        "price": "{{ifempty(2.salePrice; 2.regularPrice)}}"
                    }
                ],
                "body_html": "{{2.description}}"
            },
            "metadata": {
                "designer": {
                    "x": 1200,
                    "y": 0
                },
                "restore": {
                    "tags": {
                        "mode": "chose",
                        "items": []
                    },
                    "images": {
                        "mode": "edit"
                    },
                    "options": {
                        "mode": "chose",
                        "items": []
                    },
                    "variants": {
                        "mode": "chose",
                        "items": [
                            {
                                "taxable": {
                                    "mode": "chose"
                                },
                                "weight_unit": {
                                    "mode": "chose",
                                    "label": ""
                                },
                                "inventory_policy": {
                                    "mode": "chose",
                                    "label": ""
                                },
                                "presentment_prices": {
                                    "mode": "chose",
                                    "items": []
                                },
                                "fulfillment_service": {
                                    "mode": "chose",
                                    "label": ""
                                },
                                "inventory_management": {
                                    "mode": "chose",
                                    "label": ""
                                }
                            }
                        ]
                    },
                    "published": {
                        "mode": "chose"
                    },
                    "published_scope": {
                        "mode": "chose",
                        "label": ""
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "title",
                        "type": "text",
                        "label": "Title",
                        "required": true
                    },
                    {
                        "name": "product_type",
                        "type": "text",
                        "label": "Product type"
                    },
                    {
                        "name": "body_html",
                        "type": "text",
                        "label": "Body HTML"
                    },
                    {
                        "name": "vendor",
                        "type": "text",
                        "label": "Vendor"
                    },
                    {
                        "name": "tags",
                        "type": "array",
                        "label": "Tags"
                    },
                    {
                        "name": "published",
                        "type": "boolean",
                        "label": "Published"
                    },
                    {
                        "name": "published_at",
                        "type": "date",
                        "label": "Published at"
                    },
                    {
                        "name": "published_scope",
                        "type": "select",
                        "label": "Published scope",
                        "validate": {
                            "enum": [
                                "web",
                                "global"
                            ]
                        }
                    },
                    {
                        "name": "handle",
                        "type": "text",
                        "label": "Handle"
                    },
                    {
                        "name": "options",
                        "spec": [
                            {
                                "name": "name",
                                "type": "text",
                                "label": "Name",
                                "required": true
                            }
                        ],
                        "type": "array",
                        "label": "Options"
                    },
                    {
                        "name": "variants",
                        "spec": [
                            {
                                "name": "price",
                                "type": "number",
                                "label": "Price"
                            },
                            {
                                "name": "option1",
                                "type": "text",
                                "label": "Option 1"
                            },
                            {
                                "name": "option2",
                                "type": "text",
                                "label": "Option 2"
                            },
                            {
                                "name": "option3",
                                "type": "text",
                                "label": "Option 3"
                            },
                            {
                                "name": "sku",
                                "type": "text",
                                "label": "SKU"
                            },
                            {
                                "name": "barcode",
                                "type": "text",
                                "label": "Barcode"
                            },
                            {
                                "name": "fulfillment_service",
                                "type": "select",
                                "label": "Fulfillment service",
                                "validate": false
                            },
                            {
                                "name": "inventory_management",
                                "type": "select",
                                "label": "Inventory management",
                                "validate": false
                            },
                            {
                                "name": "inventory_policy",
                                "type": "select",
                                "label": "Inventory policy",
                                "options": [
                                    {
                                        "label": "deny",
                                        "value": "deny"
                                    },
                                    {
                                        "label": "continue",
                                        "value": "continue"
                                    }
                                ],
                                "validate": false
                            },
                            {
                                "name": "inventory_quantity",
                                "type": "number",
                                "label": "Inventory quantity"
                            },
                            {
                                "name": "grams",
                                "type": "number",
                                "label": "Grams"
                            },
                            {
                                "name": "compare_at_price",
                                "type": "text",
                                "label": "Compare at price"
                            },
                            {
                                "name": "presentment_prices",
                                "spec": [
                                    {
                                        "name": "price",
                                        "spec": [
                                            {
                                                "name": "amount",
                                                "type": "text",
                                                "label": "Amount",
                                                "required": true
                                            },
                                            {
                                                "name": "currency_code",
                                                "type": "text",
                                                "label": "Currency code",
                                                "required": true
                                            }
                                        ],
                                        "type": "collection",
                                        "label": "Price"
                                    },
                                    {
                                        "name": "compare_at_price",
                                        "spec": [
                                            {
                                                "name": "amount",
                                                "type": "text",
                                                "label": "Amount",
                                                "required": false
                                            },
                                            {
                                                "name": "currency_code",
                                                "type": "text",
                                                "label": "Currency code",
                                                "required": false
                                            }
                                        ],
                                        "type": "collection",
                                        "label": "Compare at price"
                                    }
                                ],
                                "type": "array",
                                "label": "Presentment prices"
                            },
                            {
                                "name": "position",
                                "type": "number",
                                "label": "Position"
                            },
                            {
                                "name": "taxable",
                                "type": "boolean",
                                "label": "Taxable"
                            },
                            {
                                "name": "taxcode",
                                "type": "text",
                                "label": "Tax code"
                            },
                            {
                                "name": "weight",
                                "type": "number",
                                "label": "Weight"
                            },
                            {
                                "name": "weight_unit",
                                "type": "select",
                                "label": "Weight unit",
                                "options": [
                                    {
                                        "label": "g",
                                        "value": "g"
                                    },
                                    {
                                        "label": "kg",
                                        "value": "kg"
                                    },
                                    {
                                        "label": "oz",
                                        "value": "oz"
                                    },
                                    {
                                        "label": "lb",
                                        "value": "lb"
                                    }
                                ]
                            }
                        ],
                        "type": "array",
                        "label": "Variants"
                    },
                    {
                        "name": "images",
                        "spec": [
                            {
                                "name": "data",
                                "type": "buffer",
                                "label": "Data",
                                "required": true
                            },
                            {
                                "name": "alt",
                                "type": "text",
                                "label": "Alternate text"
                            },
                            {
                                "name": "position",
                                "type": "number",
                                "label": "Position"
                            }
                        ],
                        "type": "array",
                        "label": "Images"
                    },
                    {
                        "name": "template_suffix",
                        "type": "text",
                        "label": "Template suffix"
                    },
                    {
                        "name": "metafields_global_title_tag",
                        "type": "text",
                        "label": "Metafields global title tag"
                    },
                    {
                        "name": "metafields_global_description_tag",
                        "type": "text",
                        "label": "Metafields global description tag"
                    }
                ],
                "advanced": true
            }
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {
            "orphans": []
        },
        "zone": "eu1.make.com",
        "notes": []
    }
}