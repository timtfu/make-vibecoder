                    "QTY": "{{1.`2`}}",
                    "Date": "{{now}}",
                    "Price": "{{1.`3`}}",
                    "Taxes": "{{1.`5`}}",
                    "Total": "{{1.`6`}}",
                    "Subtotal": "{{1.`4`}}",
