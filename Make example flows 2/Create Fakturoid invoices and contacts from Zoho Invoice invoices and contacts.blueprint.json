{
    "name": "Create Fakturoid invoices and contacts from Zoho Invoice invoices and contacts",
    "flow": [
        {
            "id": 1,
            "module": "zoho-invoice:watchInvoices",
            "version": 1,
            "parameters": {
                "limit": 10,
                "choose": "created",
                "filter_by": "",
                "sort_column": ""
            },
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 150
                },
                "restore": {
                    "choose": {
                        "label": "Created Date"
                    },
                    "filter_by": {
                        "label": ""
                    },
                    "sort_column": {
                        "label": ""
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    },
                    {
                        "name": "choose",
                        "type": "select",
                        "label": "Watch",
                        "required": true,
                        "validate": {
                            "enum": [
                                "created",
                                "updated"
                            ]
                        }
                    },
                    {
                        "name": "item_id",
                        "type": "select",
                        "label": "Select Item"
                    },
                    {
                        "name": "status",
                        "type": "select",
                        "label": "Status",
                        "validate": {
                            "enum": [
                                "sent",
                                "Draft",
                                "overdue",
                                "paid",
                                "void",
                                "unpaid",
                                "partially_paid",
                                "viewed"
                            ]
                        }
                    },
                    {
                        "name": "filter_by",
                        "type": "select",
                        "label": "Filter By",
                        "validate": {
                            "enum": [
                                "Status.All",
                                "Status.Sent",
                                "Status.Draft",
                                "Status.OverDue",
                                "Status.Paid",
                                "Status.Void",
                                "Status.Unpaid",
                                "Status.PartiallyPaid",
                                "Status.Viewed",
                                "Date.PaymentExpectedDate"
                            ]
                        }
                    },
                    {
                        "name": "sort_column",
                        "type": "select",
                        "label": "Sort Column",
                        "validate": {
                            "enum": [
                                "customer_name",
                                "invoice_number",
                                "date",
                                "due_date",
                                "total",
                                "balance",
                                "created_time"
                            ]
                        }
                    },
                    {
                        "name": "limit",
                        "type": "uinteger",
                        "label": "Limit",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 2,
            "module": "zoho-invoice:getContact",
            "version": 1,
            "parameters": {},
            "mapper": {
                "contact_id": "{{1.customer_id}}"
            },
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 150
                },
                "restore": {
                    "contact_id": {
                        "mode": "edit"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "mode": "edit",
                        "name": "contact_id",
                        "type": "select",
                        "label": "Contact ID",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 5,
            "module": "fakturoid:ActionSearchSubject",
            "version": 1,
            "parameters": {},
            "mapper": {
                "query": "{{2.contact_name}}",
                "maxResults": "10"
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 150
                },
                "restore": {},
                "parameters": [
                    {
                        "name": "account",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    },
                    {
                        "name": "continueWhenNoRes",
                        "type": "boolean",
                        "label": "Continue the execution of the route even if the module returns no results",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "query",
                        "type": "text",
                        "label": "Query"
                    },
                    {
                        "name": "maxResults",
                        "type": "uinteger",
                        "label": "Maximum number of returned contacts",
                        "required": true
                    },
                    {
                        "name": "slug",
                        "type": "select",
                        "label": "Account",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 3,
            "module": "fakturoid:ActionCreateSubject",
            "version": 1,
            "parameters": {},
            "mapper": {
                "web": "",
                "zip": "",
                "city": "",
                "iban": "",
                "name": "{{2.company_name}}",
                "email": "",
                "phone": "",
                "vatNo": "",
                "street": "",
                "country": "",
                "street2": "",
                "customId": "",
                "fullName": "{{2.contact_name}}",
                "emailCopy": "",
                "bankAccount": "",
                "registrationNo": "",
                "variableSymbol": ""
            },
            "metadata": {
                "designer": {
                    "x": 900,
                    "y": 150
                },
                "restore": {},
                "parameters": [
                    {
                        "name": "account",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "name",
                        "type": "text",
                        "label": "Company name",
                        "required": true
                    },
                    {
                        "name": "street",
                        "type": "text",
                        "label": "Street"
                    },
                    {
                        "name": "street2",
                        "type": "text",
                        "label": "Street 2"
                    },
                    {
                        "name": "city",
                        "type": "text",
                        "label": "City"
                    },
                    {
                        "name": "zip",
                        "type": "number",
                        "label": "ZIP"
                    },
                    {
                        "name": "registrationNo",
                        "type": "text",
                        "label": "Registration No."
                    },
                    {
                        "name": "vatNo",
                        "type": "text",
                        "label": "VAT No. (VAT payers)"
                    },
                    {
                        "name": "bankAccount",
                        "type": "text",
                        "label": "Bank account number"
                    },
                    {
                        "name": "fullName",
                        "type": "text",
                        "label": "Contact person's full name "
                    },
                    {
                        "name": "email",
                        "type": "email",
                        "label": "Email address where to send invoices "
                    },
                    {
                        "name": "phone",
                        "type": "text",
                        "label": "Phone"
                    },
                    {
                        "name": "web",
                        "type": "url",
                        "label": "Web"
                    },
                    {
                        "name": "country",
                        "type": "text",
                        "label": "Country (ISO code)"
                    },
                    {
                        "name": "variableSymbol",
                        "type": "text",
                        "label": "Variable symbol"
                    },
                    {
                        "name": "iban",
                        "type": "text",
                        "label": "IBAN"
                    },
                    {
                        "name": "emailCopy",
                        "type": "email",
                        "label": "Email address where to send invoice copies"
                    },
                    {
                        "name": "customId",
                        "type": "text",
                        "label": "ID of the contact in your application"
                    },
                    {
                        "name": "slug",
                        "type": "select",
                        "label": "Account",
                        "required": true
                    }
                ]
            },
            "onerror": [
                {
                    "id": 6,
                    "module": "builtin:Resume",
                    "version": 1,
                    "parameters": {},
                    "filter": {
                        "name": "",
                        "conditions": [
                            [
                                {
                                    "a": "{{3.error.type}}",
                                    "b": "DataError",
                                    "o": "text:equal"
                                }
                            ]
                        ]
                    },
                    "mapper": {
                        "id": "{{5.id}}"
                    },
                    "metadata": {
                        "designer": {
                            "x": 1200,
                            "y": 300
                        },
                        "expect": [
                            {
                                "name": "id",
                                "type": "number",
                                "label": "Contact ID"
                            }
                        ]
                    }
                }
            ]
        },
        {
            "id": 4,
            "module": "fakturoid:ActionCreateInvoice",
            "version": 1,
            "parameters": {},
            "mapper": {
                "due": "",
                "iban": "",
                "note": "",
                "number": "",
                "currency": "",
                "language": "cz",
                "proforma": false,
                "swiftBic": "",
                "relatedId": "",
                "subjectId": "{{3.id}}",
                "footerNote": "",
                "supplyCode": "",
                "orderNumber": "",
                "privateNote": "",
                "exchangeRate": "",
                "variableSymbol": "",
                "partialProforma": false,
                "taxableFulfillmentDue": "",
                "transferredTaxLiability": false
            },
            "metadata": {
                "designer": {
                    "x": 1200,
                    "y": 0
                },
                "restore": {
                    "language": {
                        "mode": "chose",
                        "label": "Czech"
                    },
                    "proforma": {
                        "mode": "chose"
                    },
                    "subjectId": {
                        "mode": "edit"
                    },
                    "partialProforma": {
                        "mode": "chose"
                    },
                    "transferredTaxLiability": {
                        "mode": "chose"
                    }
                },
                "parameters": [
                    {
                        "name": "account",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "lines",
                        "spec": [
                            {
                                "name": "name",
                                "type": "text",
                                "label": "Name",
                                "required": true
                            },
                            {
                                "name": "quantity",
                                "type": "number",
                                "label": "Quantity",
                                "required": true
                            },
                            {
                                "name": "unitName",
                                "type": "text",
                                "label": "Unit name"
                            },
                            {
                                "name": "unitPrice",
                                "type": "number",
                                "label": "Unit price",
                                "required": true
                            },
                            {
                                "name": "vatRate",
                                "type": "number",
                                "label": "VAT rate",
                                "required": true
                            }
                        ],
                        "type": "array",
                        "label": "Invoice lines",
                        "labels": {
                            "add": "Adding a line",
                            "edit": "Editing a line",
                            "field": "Add a line"
                        }
                    },
                    {
                        "name": "paymentMethod",
                        "type": "select",
                        "label": "Payment method",
                        "required": true,
                        "validate": {
                            "enum": [
                                "bank",
                                "cash",
                                "cod",
                                "paypal",
                                "card"
                            ]
                        }
                    },
                    {
                        "name": "issuedOn",
                        "type": "date",
                        "label": "Issued on"
                    },
                    {
                        "name": "taxableFulfillmentDue",
                        "type": "date",
                        "label": "Taxable fulfillment date"
                    },
                    {
                        "name": "due",
                        "type": "number",
                        "label": "The number of days before the payment due date"
                    },
                    {
                        "name": "number",
                        "type": "text",
                        "label": "Invoice number"
                    },
                    {
                        "name": "orderNumber",
                        "type": "text",
                        "label": "Order number"
                    },
                    {
                        "name": "variableSymbol",
                        "type": "text",
                        "label": "Variable symbol"
                    },
                    {
                        "name": "note",
                        "type": "text",
                        "label": "Note above the invoice lines",
                        "multiline": true
                    },
                    {
                        "name": "footerNote",
                        "type": "text",
                        "label": "Footer of the invoice",
                        "multiline": true
                    },
                    {
                        "name": "privateNote",
                        "type": "text",
                        "label": "Private note",
                        "multiline": true
                    },
                    {
                        "name": "iban",
                        "type": "text",
                        "label": "IBAN"
                    },
                    {
                        "name": "swiftBic",
                        "type": "text",
                        "label": "BIC"
                    },
                    {
                        "name": "currency",
                        "type": "text",
                        "label": "Currency code"
                    },
                    {
                        "name": "exchangeRate",
                        "type": "number",
                        "label": "Exchange rate"
                    },
                    {
                        "name": "language",
                        "type": "select",
                        "label": "Language in which the invoice is drawn up",
                        "required": true,
                        "validate": {
                            "enum": [
                                "cz",
                                "sk",
                                "en",
                                "de",
                                "fr"
                            ]
                        }
                    },
                    {
                        "name": "transferredTaxLiability",
                        "type": "boolean",
                        "label": "Transferred tax liability",
                        "required": true
                    },
                    {
                        "name": "supplyCode",
                        "type": "text",
                        "label": "Supply code for recapitulative statements"
                    },
                    {
                        "name": "proforma",
                        "type": "boolean",
                        "label": "This is a proforma invoice.",
                        "required": true
                    },
                    {
                        "name": "partialProforma",
                        "type": "boolean",
                        "label": "This is a partial proforma invoice.",
                        "required": true
                    },
                    {
                        "name": "relatedId",
                        "type": "number",
                        "label": "Proforma invoice/invoice ID"
                    },
                    {
                        "name": "slug",
                        "type": "select",
                        "label": "Account",
                        "required": true
                    },
                    {
                        "name": "subjectId",
                        "type": "select",
                        "label": "Contact",
                        "required": true
                    },
                    {
                        "name": "bankAccountType",
                        "type": "select",
                        "label": "Ways of specifying a bank account ",
                        "required": true,
                        "validate": {
                            "enum": [
                                "id",
                                "value",
                                "empty"
                            ]
                        }
                    },
                    {
                        "name": "bankAccountId",
                        "type": "select",
                        "label": "Bank account",
                        "required": true
                    }
                ]
            }
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {
            "orphans": []
        },
        "zone": "eu1.make.com",
        "notes": []
    }
}