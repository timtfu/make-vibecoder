{
    "name": "Add new Productboard features as tasks in Asana",
    "flow": [
        {
            "id": 1,
            "module": "productboard:newFeature",
            "version": 1,
            "parameters": {},
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 0
                },
                "restore": {},
                "parameters": [
                    {
                        "name": "__IMTHOOK__",
                        "type": "hook",
                        "label": "Webhook",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 2,
            "module": "productboard:getFeature",
            "version": 1,
            "parameters": {},
            "mapper": {
                "id": "{{1.id}}"
            },
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 0
                },
                "restore": {
                    "id": {
                        "mode": "edit"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "mode": "edit",
                        "name": "id",
                        "type": "select",
                        "label": "Feature ID",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 3,
            "module": "asana:CreateTask",
            "version": 2,
            "parameters": {},
            "mapper": {
                "name": "{{2.name}}",
                "notes": "{{2.description}}",
                "external": {},
                "ignoreMe": "no",
                "destination": "projects",
                "ignoreMeTwo": "no"
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 0
                },
                "restore": {
                    "due": {
                        "mode": "chose",
                        "label": ""
                    },
                    "tags": {
                        "mode": "chose"
                    },
                    "liked": {
                        "mode": "chose"
                    },
                    "ignoreMe": {
                        "mode": "chose",
                        "label": "No"
                    },
                    "completed": {
                        "mode": "chose"
                    },
                    "followers": {
                        "mode": "chose",
                        "items": []
                    },
                    "destination": {
                        "mode": "chose",
                        "label": "Projects"
                    },
                    "ignoreMeTwo": {
                        "mode": "chose",
                        "label": "No"
                    },
                    "workspaceAlt": {
                        "mode": "edit"
                    },
                    "workspaceAlt2": {
                        "mode": "edit"
                    },
                    "assignee_status": {
                        "mode": "chose",
                        "label": ""
                    },
                    "resource_subtype": {
                        "mode": "chose",
                        "label": ""
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "destination",
                        "type": "select",
                        "label": "Task destination",
                        "required": true,
                        "validate": {
                            "enum": [
                                "workspace",
                                "projects",
                                "projAndSect",
                                "parentTaskSelect",
                                "parentTaskMap"
                            ]
                        }
                    },
                    {
                        "name": "name",
                        "type": "text",
                        "label": "Task Name"
                    },
                    {
                        "name": "notes",
                        "type": "text",
                        "label": "Notes"
                    },
                    {
                        "name": "html_notes",
                        "type": "text",
                        "label": "HTML Notes"
                    },
                    {
                        "mode": "edit",
                        "name": "workspaceAlt",
                        "type": "select",
                        "label": "Workspace ID"
                    },
                    {
                        "name": "due",
                        "type": "select",
                        "label": "Due",
                        "validate": {
                            "enum": [
                                "date",
                                "datetime"
                            ]
                        }
                    },
                    {
                        "name": "resource_subtype",
                        "type": "select",
                        "label": "Resource Subtype",
                        "validate": {
                            "enum": [
                                "approval",
                                "default_task",
                                "milestone"
                            ]
                        }
                    },
                    {
                        "name": "liked",
                        "type": "boolean",
                        "label": "Liked"
                    },
                    {
                        "name": "completed",
                        "type": "boolean",
                        "label": "Task Completed?"
                    },
                    {
                        "name": "external",
                        "spec": [
                            {
                                "name": "gid",
                                "type": "text",
                                "label": "External ID",
                                "validate": {
                                    "max": 1024
                                }
                            },
                            {
                                "name": "data",
                                "type": "text",
                                "label": "External Data"
                            }
                        ],
                        "type": "collection",
                        "label": "External"
                    },
                    {
                        "mode": "edit",
                        "name": "workspaceAlt2",
                        "type": "select",
                        "label": "Workspace ID"
                    },
                    {
                        "name": "tags",
                        "type": "select",
                        "label": "Tags",
                        "multiple": true
                    },
                    {
                        "name": "workspace",
                        "type": "select",
                        "label": "Workspace ID",
                        "required": true
                    },
                    {
                        "name": "assignee",
                        "type": "any",
                        "label": "Task Assignee ID"
                    },
                    {
                        "name": "assignee_status",
                        "type": "select",
                        "label": "Assignee Status",
                        "validate": {
                            "enum": [
                                "inbox",
                                "later",
                                "today",
                                "upcoming"
                            ]
                        }
                    },
                    {
                        "name": "followers",
                        "spec": {
                            "type": "any"
                        },
                        "type": "array",
                        "label": "Followers"
                    },
                    {
                        "name": "projects",
                        "type": "select",
                        "label": "Projects",
                        "multiple": true,
                        "required": true
                    },
                    {
                        "name": "ignoreMe",
                        "type": "select",
                        "label": "Generate Workspace Custom Fields",
                        "validate": {
                            "enum": [
                                "no",
                                "yes"
                            ]
                        }
                    },
                    {
                        "name": "ignoreMeTwo",
                        "type": "select",
                        "label": "Generate Workspace Projects Custom Fields",
                        "validate": {
                            "enum": [
                                "no",
                                "yes"
                            ]
                        }
                    }
                ]
            }
        }
    ],
    "metadata": {
        "instant": true,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {
            "orphans": []
        },
        "zone": "eu1.make.com",
        "notes": []
    }
}