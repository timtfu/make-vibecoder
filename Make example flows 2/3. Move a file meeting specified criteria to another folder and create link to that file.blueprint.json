{
    "name": "3. Move a file meeting specified criteria to another folder and create link to that file",
    "flow": [
        {
            "id": 5,
            "module": "egnyte:SearchFilesFolders",
            "version": 1,
            "parameters": {},
            "mapper": {
                "path": "/Shared/Pending",
                "type": "FILE",
                "limit": "10",
                "query": "pending*",
                "custom_metadata": [
                    {
                        "key": "approval",
                        "value": "TRUE",
                        "operator": "EQUALS",
                        "namespace": "approval"
                    },
                    {
                        "key": "approval2",
                        "value": "TRUE",
                        "operator": "EQUALS",
                        "namespace": "approval"
                    }
                ]
            },
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 0
                },
                "restore": {
                    "path": {
                        "mode": "edit"
                    },
                    "type": {
                        "mode": "chose",
                        "label": "Only files"
                    },
                    "custom_metadata": {
                        "mode": "chose",
                        "items": [
                            {
                                "key": {
                                    "mode": "chose",
                                    "label": "approval1"
                                },
                                "operator": {
                                    "mode": "chose",
                                    "label": "EQUALS"
                                },
                                "namespace": {
                                    "mode": "chose",
                                    "label": "Approval"
                                }
                            },
                            {
                                "key": {
                                    "mode": "chose",
                                    "label": "approval2"
                                },
                                "operator": {
                                    "mode": "chose",
                                    "label": "EQUALS"
                                },
                                "namespace": {
                                    "mode": "chose",
                                    "label": "Approval"
                                }
                            }
                        ]
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "query",
                        "type": "text",
                        "label": "Query"
                    },
                    {
                        "name": "path",
                        "type": "folder",
                        "label": "Folder path"
                    },
                    {
                        "name": "modified_before",
                        "type": "date",
                        "label": "Modified before"
                    },
                    {
                        "name": "modified_after",
                        "type": "date",
                        "label": "Modified after"
                    },
                    {
                        "name": "type",
                        "type": "select",
                        "label": "Type",
                        "validate": {
                            "enum": [
                                "ALL",
                                "FILE",
                                "FOLDER"
                            ]
                        }
                    },
                    {
                        "name": "namespaces",
                        "type": "select",
                        "label": "Namespaces",
                        "multiple": true
                    },
                    {
                        "name": "custom_metadata",
                        "spec": [
                            {
                                "name": "namespace",
                                "type": "select",
                                "label": "Namespace",
                                "required": true
                            },
                            {
                                "name": "operator",
                                "type": "select",
                                "label": "Operator",
                                "options": [
                                    {
                                        "label": "EQUALS",
                                        "value": "EQUALS"
                                    },
                                    {
                                        "label": "GREATER_THAN",
                                        "value": "GREATER_THAN"
                                    },
                                    {
                                        "label": "LESS_THAN",
                                        "value": "LESS_THAN"
                                    },
                                    {
                                        "label": "CONTAINS",
                                        "value": "CONTAINS"
                                    }
                                ],
                                "required": true
                            },
                            {
                                "name": "value",
                                "type": "text",
                                "label": "Value"
                            }
                        ],
                        "type": "array",
                        "label": "Custom metadata"
                    },
                    {
                        "name": "limit",
                        "type": "uinteger",
                        "label": "Limit"
                    }
                ]
            }
        },
        {
            "id": 6,
            "module": "egnyte:moveFile",
            "version": 1,
            "parameters": {
                "__IMTCONN__": 1058512
            },
            "filter": {
                "name": "",
                "conditions": [
                    [
                        {
                            "a": "{{5.`__IMTLENGTH__`}}",
                            "b": "0",
                            "o": "number:notequal"
                        }
                    ]
                ]
            },
            "mapper": {
                "path": "{{5.path}}",
                "newName": "{{replace(5.name; \"pending \"; emptystring)}}",
                "id_or_path": "path",
                "destination": "/Shared/Approved/{{get(map(5.custom_properties; \"value\"); 2)}}"
            },
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 0
                },
                "restore": {
                    "path": {
                        "mode": "edit"
                    },
                    "id_or_path": {
                        "label": "Path"
                    },
                    "__IMTCONN__": {
                        "label": "Integromat (integromat)"
                    },
                    "destination": {
                        "mode": "edit"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "id_or_path",
                        "type": "select",
                        "label": "Map ID or select a path",
                        "required": true,
                        "validate": {
                            "enum": [
                                "id",
                                "path"
                            ]
                        }
                    },
                    {
                        "name": "destination",
                        "type": "folder",
                        "label": "Destination",
                        "required": true
                    },
                    {
                        "name": "newName",
                        "type": "text",
                        "label": "New name"
                    },
                    {
                        "name": "path",
                        "type": "file",
                        "label": "File path",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 14,
            "module": "egnyte:createAFileLink",
            "version": 1,
            "parameters": {},
            "mapper": {
                "path": "{{6.path}}",
                "notify": false,
                "protection": false,
                "send_email": false,
                "accessibility": "anyone"
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 0
                },
                "restore": {
                    "path": {
                        "mode": "edit"
                    },
                    "notify": {
                        "mode": "chose"
                    },
                    "protection": {
                        "mode": "chose"
                    },
                    "send_email": {
                        "mode": "chose"
                    },
                    "accessibility": {
                        "mode": "chose",
                        "label": "Anyone"
                    },
                    "add_file_name": {
                        "mode": "chose"
                    },
                    "link_to_current": {
                        "mode": "chose"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "path",
                        "type": "file",
                        "label": "File",
                        "required": true
                    },
                    {
                        "name": "accessibility",
                        "type": "select",
                        "label": "Accessibility",
                        "required": true,
                        "validate": {
                            "enum": [
                                "anyone",
                                "password",
                                "domain",
                                "recipients"
                            ]
                        }
                    },
                    {
                        "name": "link_to_current",
                        "type": "boolean",
                        "label": "Link to current"
                    },
                    {
                        "name": "add_file_name",
                        "type": "boolean",
                        "label": "Add file name"
                    },
                    {
                        "name": "protection",
                        "type": "boolean",
                        "label": "View only",
                        "required": true
                    },
                    {
                        "name": "expiry_date",
                        "time": true,
                        "type": "date",
                        "label": "Expire date"
                    },
                    {
                        "name": "expiry_clicks",
                        "type": "uinteger",
                        "label": "Expire clicks",
                        "validate": {
                            "max": 10,
                            "min": 1
                        }
                    },
                    {
                        "name": "send_email",
                        "type": "boolean",
                        "label": "Send email",
                        "required": true
                    },
                    {
                        "name": "notify",
                        "type": "boolean",
                        "label": "Notify",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 15,
            "module": "util:TextAggregator",
            "version": 1,
            "parameters": {
                "feeder": 5,
                "rowSeparator": "\n"
            },
            "mapper": {
                "value": "{{replace(5.name; \"pending\"; emptystring)}} -> {{14.links[].url}}"
            },
            "metadata": {
                "designer": {
                    "x": 900,
                    "y": 0
                },
                "restore": {
                    "feeder": {
                        "label": "Egnyte - Search Files and Folders [5]"
                    },
                    "rowSeparator": {
                        "label": "New row"
                    }
                },
                "parameters": [
                    {
                        "name": "rowSeparator",
                        "type": "select",
                        "label": "Row separator",
                        "validate": {
                            "enum": [
                                "\n",
                                "\t",
                                "other"
                            ]
                        }
                    }
                ],
                "expect": [
                    {
                        "name": "value",
                        "type": "text",
                        "label": "Text",
                        "multiline": true
                    }
                ],
                "advanced": true
            },
            "flags": {
                "stopIfEmpty": true
            }
        },
        {
            "id": 13,
            "module": "slack:CreateMessage",
            "version": 3,
            "parameters": {},
            "mapper": {
                "text": "New files were approved:\n{{15.text}}",
                "parse": false,
                "mrkdwn": true
            },
            "metadata": {
                "designer": {
                    "x": 1200,
                    "y": 0
                },
                "restore": {
                    "parse": {
                        "mode": "chose"
                    },
                    "mrkdwn": {
                        "mode": "chose"
                    },
                    "as_user": {
                        "mode": "chose"
                    },
                    "link_names": {
                        "mode": "chose"
                    },
                    "attachments": {
                        "mode": "chose",
                        "items": []
                    },
                    "unfurl_links": {
                        "mode": "chose"
                    },
                    "unfurl_media": {
                        "mode": "chose"
                    },
                    "reply_broadcast": {
                        "mode": "chose"
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "channel",
                        "type": "select",
                        "label": "Channel",
                        "required": true
                    },
                    {
                        "name": "text",
                        "type": "text",
                        "label": "Text",
                        "required": true,
                        "multiline": true
                    },
                    {
                        "name": "as_user",
                        "type": "boolean",
                        "label": "As user"
                    },
                    {
                        "name": "thread_ts",
                        "type": "text",
                        "label": "Thread message ID (time stamp)"
                    },
                    {
                        "name": "reply_broadcast",
                        "type": "boolean",
                        "label": "Reply broadcast"
                    },
                    {
                        "name": "attachments",
                        "spec": [
                            {
                                "name": "fallback",
                                "type": "text",
                                "label": "Fallback",
                                "required": true
                            },
                            {
                                "name": "color",
                                "type": "text",
                                "label": "Color"
                            },
                            {
                                "name": "pretext",
                                "type": "text",
                                "label": "Pretext"
                            },
                            {
                                "name": "author_name",
                                "type": "text",
                                "label": "Author name"
                            },
                            {
                                "name": "author_link",
                                "type": "url",
                                "label": "Author link"
                            },
                            {
                                "name": "author_icon",
                                "type": "url",
                                "label": "Author icon (URL)"
                            },
                            {
                                "name": "title",
                                "type": "text",
                                "label": "Title"
                            },
                            {
                                "name": "title_link",
                                "type": "url",
                                "label": "Title link"
                            },
                            {
                                "name": "text",
                                "type": "text",
                                "label": "Text"
                            },
                            {
                                "name": "image_url",
                                "type": "text",
                                "label": "Image (URL)"
                            },
                            {
                                "name": "thumb_url",
                                "type": "url",
                                "label": "Thumbnail (URL)"
                            },
                            {
                                "name": "footer",
                                "type": "text",
                                "label": "Footer"
                            },
                            {
                                "name": "footer_icon",
                                "type": "url",
                                "label": "Footer icon (URL)"
                            },
                            {
                                "name": "ts",
                                "type": "number",
                                "label": "Time stamp"
                            },
                            {
                                "name": "fields",
                                "spec": [
                                    {
                                        "name": "title",
                                        "type": "text",
                                        "label": "Title",
                                        "required": true
                                    },
                                    {
                                        "name": "value",
                                        "type": "text",
                                        "label": "Value",
                                        "required": true
                                    },
                                    {
                                        "name": "short",
                                        "type": "boolean",
                                        "label": "Display side-by-side with other values",
                                        "required": true
                                    }
                                ],
                                "type": "array",
                                "label": "Fields inside message attachments"
                            }
                        ],
                        "type": "array",
                        "label": "Attachments"
                    },
                    {
                        "name": "icon_emoji",
                        "type": "text",
                        "label": "Icon emoji"
                    },
                    {
                        "name": "icon_url",
                        "type": "url",
                        "label": "Icon url"
                    },
                    {
                        "name": "link_names",
                        "type": "boolean",
                        "label": "Link names"
                    },
                    {
                        "name": "parse",
                        "type": "boolean",
                        "label": "Parse message text"
                    },
                    {
                        "name": "mrkdwn",
                        "type": "boolean",
                        "label": "Use markdown"
                    },
                    {
                        "name": "unfurl_links",
                        "type": "boolean",
                        "label": "Unfurl primarily text-based content"
                    },
                    {
                        "name": "unfurl_media",
                        "type": "boolean",
                        "label": "Unfurl media content"
                    },
                    {
                        "name": "username",
                        "type": "text",
                        "label": "User name"
                    }
                ]
            }
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {
            "orphans": []
        },
        "zone": "eu1.make.com",
        "notes": []
    }
}