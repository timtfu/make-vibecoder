{
    "name": "Create a new project in FogBugz from a new project in Asana",
    "flow": [
        {
            "id": 1,
            "module": "asana:WatchProjects",
            "version": 2,
            "parameters": {
                "page": 1000,
                "workspace": ""
            },
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": 0,
                    "y": 150
                },
                "restore": {
                    "workspace": {
                        "label": ""
                    }
                },
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    },
                    {
                        "name": "workspace",
                        "type": "select",
                        "label": "Workspace ID"
                    },
                    {
                        "name": "archived",
                        "type": "boolean",
                        "label": "Archived"
                    },
                    {
                        "name": "page",
                        "type": "uinteger",
                        "label": "Limit",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 5,
            "module": "builtin:BasicRouter",
            "version": 1,
            "mapper": null,
            "metadata": {
                "designer": {
                    "x": 300,
                    "y": 150
                }
            },
            "routes": [
                {
                    "flow": [
                        {
                            "id": 3,
                            "module": "fogbugz:listPeople",
                            "version": 1,
                            "parameters": {},
                            "mapper": {
                                "limit": "1000",
                                "fIncludeActive": true,
                                "fIncludeNormal": true,
                                "fIncludeDeleted": false,
                                "fIncludeVirtual": false,
                                "fIncludeCommunity": false
                            },
                            "metadata": {
                                "designer": {
                                    "x": 600,
                                    "y": 0
                                },
                                "restore": {
                                    "fIncludeActive": {
                                        "mode": "chose"
                                    },
                                    "fIncludeNormal": {
                                        "mode": "chose"
                                    },
                                    "fIncludeDeleted": {
                                        "mode": "chose"
                                    },
                                    "fIncludeVirtual": {
                                        "mode": "chose"
                                    },
                                    "fIncludeCommunity": {
                                        "mode": "chose"
                                    }
                                },
                                "parameters": [
                                    {
                                        "name": "__IMTCONN__",
                                        "type": "account",
                                        "label": "Connection",
                                        "required": true
                                    }
                                ],
                                "expect": [
                                    {
                                        "name": "fIncludeActive",
                                        "type": "boolean",
                                        "label": "Include Active",
                                        "required": true
                                    },
                                    {
                                        "name": "fIncludeNormal",
                                        "type": "boolean",
                                        "label": "Include Normal",
                                        "required": true
                                    },
                                    {
                                        "name": "fIncludeDeleted",
                                        "type": "boolean",
                                        "label": "Include Deleted",
                                        "required": true
                                    },
                                    {
                                        "name": "fIncludeCommunity",
                                        "type": "boolean",
                                        "label": "Include Community",
                                        "required": true
                                    },
                                    {
                                        "name": "fIncludeVirtual",
                                        "type": "boolean",
                                        "label": "Include Virtual",
                                        "required": true
                                    },
                                    {
                                        "name": "limit",
                                        "type": "uinteger",
                                        "label": "Limit"
                                    }
                                ]
                            }
                        },
                        {
                            "id": 6,
                            "module": "util:SetVariable2",
                            "version": 1,
                            "parameters": {},
                            "mapper": {
                                "name": "person_id",
                                "scope": "roundtrip",
                                "value": "{{3.ixPerson}}"
                            },
                            "metadata": {
                                "designer": {
                                    "x": 900,
                                    "y": 0
                                },
                                "restore": {
                                    "scope": {
                                        "label": "One cycle"
                                    }
                                },
                                "expect": [
                                    {
                                        "name": "name",
                                        "type": "text",
                                        "label": "Variable name",
                                        "required": true
                                    },
                                    {
                                        "name": "scope",
                                        "type": "select",
                                        "label": "Variable lifetime",
                                        "required": true,
                                        "validate": {
                                            "enum": [
                                                "roundtrip",
                                                "execution"
                                            ]
                                        }
                                    },
                                    {
                                        "name": "value",
                                        "type": "any",
                                        "label": "Variable value"
                                    }
                                ],
                                "interface": [
                                    {
                                        "name": "person_id",
                                        "type": "any",
                                        "label": "person_id"
                                    }
                                ]
                            }
                        }
                    ]
                },
                {
                    "flow": [
                        {
                            "id": 9,
                            "module": "util:GetVariable2",
                            "version": 1,
                            "parameters": {},
                            "mapper": {
                                "name": "person_id"
                            },
                            "metadata": {
                                "designer": {
                                    "x": 600,
                                    "y": 300
                                },
                                "expect": [
                                    {
                                        "name": "name",
                                        "type": "text",
                                        "label": "Variable name",
                                        "required": true
                                    }
                                ],
                                "interface": [
                                    {
                                        "name": "person_id",
                                        "type": "any",
                                        "label": "person_id"
                                    }
                                ]
                            }
                        },
                        {
                            "id": 2,
                            "module": "fogbugz:createAProject",
                            "version": 1,
                            "parameters": {},
                            "mapper": {
                                "fInbox": false,
                                "sProject": "{{1.name}}",
                                "fAllowPublicSubmit": false,
                                "ixPersonPrimaryContact": "{{ifempty(9.person_id; 2)}}"
                            },
                            "metadata": {
                                "designer": {
                                    "x": 900,
                                    "y": 300
                                },
                                "restore": {
                                    "fInbox": {
                                        "mode": "chose"
                                    },
                                    "fAllowPublicSubmit": {
                                        "mode": "chose"
                                    },
                                    "ixPersonPrimaryContact": {
                                        "mode": "edit"
                                    }
                                },
                                "parameters": [
                                    {
                                        "name": "__IMTCONN__",
                                        "type": "account",
                                        "label": "Connection",
                                        "required": true
                                    }
                                ],
                                "expect": [
                                    {
                                        "name": "sProject",
                                        "type": "text",
                                        "label": "Project Name",
                                        "required": true
                                    },
                                    {
                                        "name": "ixPersonPrimaryContact",
                                        "type": "select",
                                        "label": "Person Primary Contact ID",
                                        "required": true
                                    },
                                    {
                                        "name": "fAllowPublicSubmit",
                                        "type": "boolean",
                                        "label": "Allow Public Submit",
                                        "required": true
                                    },
                                    {
                                        "name": "fInbox",
                                        "type": "boolean",
                                        "label": "Inbox",
                                        "required": true
                                    }
                                ]
                            }
                        }
                    ]
                }
            ]
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
            "slots": null,
            "confidential": false,
            "dataloss": false,
            "dlq": false,
            "freshVariables": false
        },
        "designer": {
            "orphans": []
        },
        "zone": "eu1.make.com",
        "notes": []
    }
}